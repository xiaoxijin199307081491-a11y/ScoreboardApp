{
  "expo": {
    "name": "记分板",
    "slug": "ScoreboardApp",
    "version": "1.0.0",
    "orientation": "auto",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.ScoreboardApp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.anonymous.ScoreboardApp"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "允许记分板访问您的相册来设置队伍背景图"
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "f59940a3-8fb4-468f-be6c-ef3771f8e7ce"
      }
    },
    "owner": "xiao669222071"
  }
}
